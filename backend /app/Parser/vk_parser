        print(f"Обрабатываю: {domain}")
        try:
            group = get_group_info(domain)
            posts = get_wall_posts(domain)

            for post in posts:
                event = build_event(post, group)
                if event:
                    all_events.append(event)

            print(f"  Найдено событий: {len(all_events)}")
        except Exception as e:
            import traceback
            print(f"  Ошибка в {domain}: {repr(e)}")
            traceback.print_exc()

    with open("events.json", "w", encoding="utf-8") as f:
        json.dump(all_events, f, ensure_ascii=False, indent=2)

    print(f"\nГотово. Сохранено событий: {len(all_events)}")
    print("Файл: events.json")


if __name__ == "__main__":
    main()
